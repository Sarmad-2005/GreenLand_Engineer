# PostgreSQL connection string (Neon / Supabase / local)
# Neon example: postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/greenland?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/greenland?sslmode=require"

# JWT secrets — generate with: openssl rand -base64 48
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"

# Token lifetimes
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS="7"
REMEMBER_ME_TTL_DAYS="30"

# Seeded Super Admin (used by prisma/seed.ts)
SEED_ADMIN_EMAIL="admin@greenland.ag"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="Super Admin"

# Public base URL for password-reset + email notification links.
# On Vercel you can leave this unset — email links auto-use VERCEL_PROJECT_PRODUCTION_URL
# (your *.vercel.app domain). Set it only for a custom domain or local dev.
APP_URL="http://localhost:3000"

# Email (Gmail SMTP via an App Password)
# 1) Enable 2-Step Verification on the Gmail account
# 2) Google Account → Security → App passwords → generate one (16 chars, no spaces)
# Contact-form queries are emailed to CONTACT_TO_EMAIL; newsletter notifications are sent from GMAIL_USER.
# If GMAIL_USER / GMAIL_APP_PASSWORD are unset, email sending is skipped (logged), and the app still works.
GMAIL_USER="greenlanddaska@gmail.com"
GMAIL_APP_PASSWORD="xxxxxxxxxxxxxxxx"
CONTACT_TO_EMAIL="greenlanddaska@gmail.com"

# Vercel Blob (image uploads) — read-write token from the Blob store.
# On Vercel this is injected automatically once a Blob store is connected to the project.
# For local dev, copy it from Vercel → Storage → your Blob store → .env.local tab,
# or run `vercel env pull`.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"
