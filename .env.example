# PostgreSQL connection string (Neon / Supabase / local)
# Neon example: postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/greenland?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/greenland?sslmode=require"

# JWT secrets — generate with: openssl rand -base64 48
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"

# Token lifetimes
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS="7"
REMEMBER_ME_TTL_DAYS="30"

# Seeded Super Admin (used by prisma/seed.ts)
SEED_ADMIN_EMAIL="admin@greenland.ag"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="Super Admin"

# Public base URL (password-reset links)
APP_URL="http://localhost:3000"
