// Green Land — Admin CMS schema
// Provider: PostgreSQL (Neon/Supabase). Set DATABASE_URL in .env

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

enum Status {
  ACTIVE
  INACTIVE
}

enum NewsType {
  MEETING_NOTES
  ANNOUNCEMENTS
  EVENTS
  PRESS
}

model User {
  id               String         @id @default(cuid())
  fullName         String
  email            String         @unique
  passwordHash     String
  role             Role           @default(ADMIN)
  status           Status         @default(ACTIVE)
  lastLogin        DateTime?
  failedAttempts   Int            @default(0)
  lockedUntil      DateTime?
  resetToken       String?        @unique
  resetTokenExpiry DateTime?
  deletedAt        DateTime?
  refreshTokens    RefreshToken[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([email])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  tagline     String?
  description String
  image       String?
  gallery     String[]  @default([])
  status      Status    @default(ACTIVE)
  deletedAt   DateTime?
  products    Product[]
  news        News[]
  blogs       Blog[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
}

model Product {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  description String
  price       Decimal?       @db.Decimal(12, 2)
  sku         String?        @unique
  stock       Int            @default(0)
  featured    Boolean        @default(false)
  status      Status         @default(ACTIVE)
  categoryId  String
  category    Category       @relation(fields: [categoryId], references: [id])
  images      ProductImage[]
  // Ordered list of { label, value } spec rows shown on the public product page.
  specifications Json?
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([slug])
  @@index([categoryId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  path      String
  position  Int     @default(0)
}

model News {
  id              String      @id @default(cuid())
  title           String
  slug            String      @unique
  summary         String
  featuredImage   String?
  type            NewsType    @default(ANNOUNCEMENTS)
  author          String?
  publicationDate DateTime    @default(now())
  status          Status      @default(ACTIVE)
  notifiedAt      DateTime?   // set once subscribers have been emailed about this post
  categoryId      String?
  category        Category?   @relation(fields: [categoryId], references: [id])
  images          NewsImage[]
  deletedAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([slug])
  @@index([type])
}

model NewsImage {
  id     String @id @default(cuid())
  newsId String
  news   News   @relation(fields: [newsId], references: [id], onDelete: Cascade)
  path   String
}

model Blog {
  id             String     @id @default(cuid())
  title          String
  slug           String     @unique
  excerpt        String
  content        String     // rich-text HTML
  featuredImage  String?
  tag            String?
  author         String?
  seoTitle       String?
  seoDescription String?
  featured       Boolean    @default(false)
  status         Status     @default(ACTIVE)
  notifiedAt     DateTime?  // set once subscribers have been emailed about this post
  publishedAt    DateTime   @default(now())
  categoryId     String?
  category       Category?  @relation(fields: [categoryId], references: [id])
  images         BlogImage[]
  deletedAt      DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([slug])
  @@index([tag])
}

model BlogImage {
  id     String @id @default(cuid())
  blogId String
  blog   Blog   @relation(fields: [blogId], references: [id], onDelete: Cascade)
  path   String
}

model Testimonial {
  id        String    @id @default(cuid())
  name      String
  role      String? // "Farm Owner · Green Acres Ltd"
  location  String? // "Nairobi, Kenya"
  quote     String // the review text
  photo     String? // "/uploads/..."
  rating    Int       @default(5)
  featured  Boolean   @default(false)
  status    Status    @default(ACTIVE)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status])
}

// Contact Us form submissions — emailed to the company and shown in the admin inbox.
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  product   String? // category slug picked in the form's "Product of Interest" select
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Newsletter subscribers — emailed whenever a News item or Blog post is published.
model Subscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  token          String    @unique @default(cuid()) // unguessable unsubscribe token
  unsubscribedAt DateTime? // null = active subscriber
  createdAt      DateTime  @default(now())

  @@index([unsubscribedAt])
}
